<Page x:Class="VisionMotionControl.Views.Pages.MotionControlPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
      Background="#0B0F19">
    
    <Page.Resources>
        <Style x:Key="ActionButton" TargetType="Button">
            <Setter Property="Background" Value="#3B82F6"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#60A5FA"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
        <Style x:Key="DangerButton" TargetType="Button">
            <Setter Property="Background" Value="#EF4444"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#F87171"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
        <Style x:Key="SecondaryButton" TargetType="Button">
            <Setter Property="Background" Value="#475569"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#64748B"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
        <Style x:Key="JogButton" TargetType="Button">
            <Setter Property="Background" Value="#334155"/>
            <Setter Property="Foreground" Value="#CBD5E1"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#475569"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="8"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#475569"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#3B82F6"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>
    
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        
        <!-- Header -->
        <Border Grid.Row="0" Background="#1E293B" BorderBrush="#334155" BorderThickness="1" CornerRadius="8" Padding="16" Margin="0,0,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <iconPacks:PackIconMaterialDesign Kind="Settings" Width="20" Height="20" Foreground="#3B82F6" Margin="0,0,8,0"/>
                    <TextBlock Text="三轴运动控制" FontSize="16" FontWeight="SemiBold" Foreground="White"/>
                    <Rectangle Width="1" Height="20" Fill="#334155" Margin="16,0"/>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Button Style="{StaticResource ActionButton}" Margin="0,0,8,0">
                            <StackPanel Orientation="Horizontal">
                                <iconPacks:PackIconMaterialDesign Kind="Refresh" Width="14" Height="14" Margin="0,0,6,0"/>
                                <TextBlock Text="全部回零" FontSize="12"/>
                            </StackPanel>
                        </Button>
                        <Button Style="{StaticResource SecondaryButton}">
                            <StackPanel Orientation="Horizontal">
                                <iconPacks:PackIconMaterialDesign Kind="Stop" Width="14" Height="14" Margin="0,0,6,0"/>
                                <TextBlock Text="停止所有轴" FontSize="12"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </StackPanel>
                
                <Button Grid.Column="2" Style="{StaticResource DangerButton}">
                    <StackPanel Orientation="Horizontal">
                        <iconPacks:PackIconMaterialDesign Kind="Block" Width="16" Height="16" Margin="0,0,6,0"/>
                        <TextBlock Text="全局急停" FontWeight="Bold"/>
                    </StackPanel>
                </Button>
            </Grid>
        </Border>
        
        <!-- Main Content -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1*"/>
                <ColumnDefinition Width="2*"/>
            </Grid.ColumnDefinitions>
            
            <!-- Left Column - Axis Status -->
            <Border Grid.Column="0" Background="#1E293B" BorderBrush="#334155" BorderThickness="1" CornerRadius="8" Padding="16" Margin="0,0,8,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,12">
                        <iconPacks:PackIconMaterialDesign Kind="SignalCellular4Bar" Width="16" Height="16" Foreground="#94A3B8" Margin="0,0,6,0"/>
                        <TextBlock Text="轴状态监视" FontSize="14" FontWeight="Medium" Foreground="#94A3B8"/>
                    </StackPanel>
                    
                    <StackPanel Grid.Row="1">
                        <!-- X Axis -->
                        <Border Background="#0F172A" BorderBrush="#334155" BorderThickness="1" CornerRadius="6" Padding="12" Margin="0,0,0,8">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                
                                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
                                    <Ellipse Width="10" Height="10" Fill="#3B82F6" Margin="0,0,8,0">
                                        <Ellipse.Effect>
                                            <DropShadowEffect Color="#3B82F6" BlurRadius="8" ShadowDepth="0"/>
                                        </Ellipse.Effect>
                                    </Ellipse>
                                    <TextBlock Text="X 轴" FontSize="16" FontWeight="Bold" Foreground="#E2E8F0"/>
                                    <CheckBox Content="使能" Foreground="#64748B" FontSize="11" Margin="16,0,0,0" IsChecked="True"/>
                                </StackPanel>
                                
                                <TextBlock Grid.Row="1" Text="125.045" FontSize="28" FontFamily="Consolas" Foreground="#F1F5F9" FontWeight="Bold" Margin="0,0,0,4">
                                    <Run Text=" mm" FontSize="12" Foreground="#64748B" FontFamily="Segoe UI"/>
                                </TextBlock>
                                
                                <StackPanel Grid.Row="2" Orientation="Horizontal">
                                    <Border Background="#334155" BorderBrush="#475569" BorderThickness="1" CornerRadius="4" Padding="6,2" Margin="0,0,6,0">
                                        <TextBlock Text="正限位" FontSize="11" Foreground="#64748B"/>
                                    </Border>
                                    <Border Background="#334155" BorderBrush="#475569" BorderThickness="1" CornerRadius="4" Padding="6,2" Margin="0,0,6,0">
                                        <TextBlock Text="负限位" FontSize="11" Foreground="#64748B"/>
                                    </Border>
                                    <Border Background="#334155" BorderBrush="#475569" BorderThickness="1" CornerRadius="4" Padding="6,2">
                                        <TextBlock Text="运行中" FontSize="11" Foreground="#64748B"/>
                                    </Border>
                                </StackPanel>
                            </Grid>
                        </Border>
                        
                        <!-- Y Axis -->
                        <Border Background="#0F172A" BorderBrush="#334155" BorderThickness="1" CornerRadius="6" Padding="12" Margin="0,0,0,8">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                
                                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
                                    <Ellipse Width="10" Height="10" Fill="#10B981" Margin="0,0,8,0">
                                        <Ellipse.Effect>
                                            <DropShadowEffect Color="#10B981" BlurRadius="8" ShadowDepth="0"/>
                                        </Ellipse.Effect>
                                    </Ellipse>
                                    <TextBlock Text="Y 轴" FontSize="16" FontWeight="Bold" Foreground="#E2E8F0"/>
                                    <CheckBox Content="使能" Foreground="#64748B" FontSize="11" Margin="16,0,0,0" IsChecked="True"/>
                                </StackPanel>
                                
                                <TextBlock Grid.Row="1" Text="45.002" FontSize="28" FontFamily="Consolas" Foreground="#F1F5F9" FontWeight="Bold" Margin="0,0,0,4">
                                    <Run Text=" mm" FontSize="12" Foreground="#64748B" FontFamily="Segoe UI"/>
                                </TextBlock>
                                
                                <StackPanel Grid.Row="2" Orientation="Horizontal">
                                    <Border Background="#334155" BorderBrush="#475569" BorderThickness="1" CornerRadius="4" Padding="6,2" Margin="0,0,6,0">
                                        <TextBlock Text="正限位" FontSize="11" Foreground="#64748B"/>
                                    </Border>
                                    <Border Background="#334155" BorderBrush="#475569" BorderThickness="1" CornerRadius="4" Padding="6,2" Margin="0,0,6,0">
                                        <TextBlock Text="负限位" FontSize="11" Foreground="#64748B"/>
                                    </Border>
                                    <Border Background="#10B98120" BorderBrush="#10B98140" BorderThickness="1" CornerRadius="4" Padding="6,2">
                                        <TextBlock Text="运行中" FontSize="11" Foreground="#10B981"/>
                                    </Border>
                                </StackPanel>
                            </Grid>
                        </Border>
                        
                        <!-- Z Axis -->
                        <Border Background="#0F172A" BorderBrush="#334155" BorderThickness="1" CornerRadius="6" Padding="12">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                
                                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
                                    <Ellipse Width="10" Height="10" Fill="#64748B" Margin="0,0,8,0"/>
                                    <TextBlock Text="Z 轴" FontSize="16" FontWeight="Bold" Foreground="#E2E8F0"/>
                                    <CheckBox Content="使能" Foreground="#64748B" FontSize="11" Margin="16,0,0,0" IsChecked="False"/>
                                </StackPanel>
                                
                                <TextBlock Grid.Row="1" Text="0.000" FontSize="28" FontFamily="Consolas" Foreground="#F1F5F9" FontWeight="Bold" Margin="0,0,0,4">
                                    <Run Text=" mm" FontSize="12" Foreground="#64748B" FontFamily="Segoe UI"/>
                                </TextBlock>
                                
                                <StackPanel Grid.Row="2" Orientation="Horizontal">
                                    <Border Background="#EF444420" BorderBrush="#EF444440" BorderThickness="1" CornerRadius="4" Padding="6,2" Margin="0,0,6,0">
                                        <TextBlock Text="正限位" FontSize="11" Foreground="#EF4444"/>
                                    </Border>
                                    <Border Background="#334155" BorderBrush="#475569" BorderThickness="1" CornerRadius="4" Padding="6,2" Margin="0,0,6,0">
                                        <TextBlock Text="负限位" FontSize="11" Foreground="#64748B"/>
                                    </Border>
                                    <Border Background="#334155" BorderBrush="#475569" BorderThickness="1" CornerRadius="4" Padding="6,2">
                                        <TextBlock Text="运行中" FontSize="11" Foreground="#64748B"/>
                                    </Border>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </StackPanel>
                </Grid>
            </Border>
            
            <!-- Right Column - Controls -->
            <Border Grid.Column="1" Background="#1E293B" BorderBrush="#334155" BorderThickness="1" CornerRadius="8" Padding="16">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,12">
                        <iconPacks:PackIconMaterialDesign Kind="GpsFixed" Width="16" Height="16" Foreground="#94A3B8" Margin="0,0,6,0"/>
                        <TextBlock Text="运动控制面板" FontSize="14" FontWeight="Medium" Foreground="#94A3B8"/>
                    </StackPanel>
                    
                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        
                        <!-- Jog Controls -->
                        <Border Grid.Column="0" Background="#0F172A" BorderBrush="#334155" BorderThickness="1" CornerRadius="6" Padding="16" Margin="0,0,8,0">
                            <Grid>
                                <TextBlock Text="单轴点动 (Jog)" FontSize="11" Foreground="#64748B" Margin="0,0,0,12"/>
                                
                                <Grid Margin="0,28,0,0">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    
                                    <!-- XY Jog -->
                                    <Grid Grid.Row="0" HorizontalAlignment="Center">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        
                                        <Button Grid.Row="0" Grid.Column="1" Style="{StaticResource JogButton}" Content="Y+" Width="60" Height="60" Margin="4"/>
                                        <Button Grid.Row="1" Grid.Column="0" Style="{StaticResource JogButton}" Content="X-" Width="60" Height="60" Margin="4"/>
                                        <Border Grid.Row="1" Grid.Column="1" Width="60" Height="60" Background="#334155" CornerRadius="6" Margin="4">
                                            <iconPacks:PackIconMaterialDesign Kind="GpsFixed" Width="20" Height="20" Foreground="#64748B" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <Button Grid.Row="1" Grid.Column="2" Style="{StaticResource JogButton}" Content="X+" Width="60" Height="60" Margin="4"/>
                                        <Button Grid.Row="2" Grid.Column="1" Style="{StaticResource JogButton}" Content="Y-" Width="60" Height="60" Margin="4"/>
                                    </Grid>
                                    
                                    <!-- Z Jog -->
                                    <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,16,0,0">
                                        <Button Style="{StaticResource JogButton}" Content="Z+" Width="50" Height="50" Margin="4"/>
                                        <Button Style="{StaticResource JogButton}" Content="Z-" Width="50" Height="50" Margin="4"/>
                                    </StackPanel>
                                    
                                    <!-- Step Size -->
                                    <StackPanel Grid.Row="2" Margin="0,16,0,0">
                                        <TextBlock Text="点动步长" FontSize="12" Foreground="#94A3B8" Margin="0,0,0,8"/>
                                        <ComboBox Background="#1E293B" Foreground="#E2E8F0" BorderBrush="#475569" SelectedIndex="1">
                                            <ComboBoxItem Content="0.1 mm"/>
                                            <ComboBoxItem Content="1.0 mm"/>
                                            <ComboBoxItem Content="10.0 mm"/>
                                            <ComboBoxItem Content="连续"/>
                                        </ComboBox>
                                    </StackPanel>
                                </Grid>
                            </Grid>
                        </Border>
                        
                        <!-- Absolute Positioning -->
                        <Border Grid.Column="1" Background="#0F172A" BorderBrush="#334155" BorderThickness="1" CornerRadius="6" Padding="16" Margin="8,0,0,0">
                            <Grid>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                    <iconPacks:PackIconMaterialDesign Kind="Map" Width="12" Height="12" Foreground="#64748B" Margin="0,0,4,0"/>
                                    <TextBlock Text="绝对/相对定位" FontSize="11" Foreground="#64748B"/>
                                </StackPanel>
                                
                                <StackPanel Margin="0,28,0,0">
                                    <!-- X Input -->
                                    <Grid Margin="0,0,0,12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="X" FontSize="14" FontWeight="Bold" Foreground="#94A3B8" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                        <TextBox Grid.Column="1" Text="0.000" Background="#1E293B" Foreground="#E2E8F0" BorderBrush="#475569" FontFamily="Consolas" Padding="8,4"/>
                                        <TextBlock Grid.Column="2" Text="mm" FontSize="12" Foreground="#64748B" VerticalAlignment="Center" Margin="8,0,0,0"/>
                                    </Grid>
                                    
                                    <!-- Y Input -->
                                    <Grid Margin="0,0,0,12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Y" FontSize="14" FontWeight="Bold" Foreground="#94A3B8" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                        <TextBox Grid.Column="1" Text="0.000" Background="#1E293B" Foreground="#E2E8F0" BorderBrush="#475569" FontFamily="Consolas" Padding="8,4"/>
                                        <TextBlock Grid.Column="2" Text="mm" FontSize="12" Foreground="#64748B" VerticalAlignment="Center" Margin="8,0,0,0"/>
                                    </Grid>
                                    
                                    <!-- Z Input -->
                                    <Grid Margin="0,0,0,16">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Z" FontSize="14" FontWeight="Bold" Foreground="#94A3B8" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                        <TextBox Grid.Column="1" Text="0.000" Background="#1E293B" Foreground="#E2E8F0" BorderBrush="#475569" FontFamily="Consolas" Padding="8,4"/>
                                        <TextBlock Grid.Column="2" Text="mm" FontSize="12" Foreground="#64748B" VerticalAlignment="Center" Margin="8,0,0,0"/>
                                    </Grid>
                                    
                                    <!-- Speed -->
                                    <Grid Margin="0,0,0,16">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="速度" FontSize="12" Foreground="#94A3B8" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                        <Slider Grid.Column="1" Minimum="0" Maximum="100" Value="50" Background="#334155" Foreground="#3B82F6"/>
                                        <TextBlock Grid.Column="2" Text="50%" FontSize="12" Foreground="#E2E8F0" FontFamily="Consolas" VerticalAlignment="Center" Margin="8,0,0,0"/>
                                    </Grid>
                                    
                                    <!-- Action Buttons -->
                                    <StackPanel>
                                        <Button Style="{StaticResource ActionButton}" Margin="0,0,0,8">
                                            <StackPanel Orientation="Horizontal">
                                                <iconPacks:PackIconMaterialDesign Kind="PlayArrow" Width="16" Height="16" Margin="0,0,6,0"/>
                                                <TextBlock Text="绝对定位执行" FontSize="12"/>
                                            </StackPanel>
                                        </Button>
                                        <Button Style="{StaticResource SecondaryButton}">
                                            <StackPanel Orientation="Horizontal">
                                                <iconPacks:PackIconMaterialDesign Kind="PlayArrow" Width="16" Height="16" Margin="0,0,6,0"/>
                                                <TextBlock Text="相对定位执行" FontSize="12"/>
                                            </StackPanel>
                                        </Button>
                                    </StackPanel>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </Grid>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Page>
