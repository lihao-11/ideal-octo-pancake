<Page x:Class="VisionMotionControl.Views.Pages.VisionDetectPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
      Background="#0B0F19">
    
    <Page.Resources>
        <Style x:Key="ActionButton" TargetType="Button">
            <Setter Property="Background" Value="#3B82F6"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#60A5FA"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
        <Style x:Key="SecondaryButton" TargetType="Button">
            <Setter Property="Background" Value="#475569"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#64748B"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>
    
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        
        <!-- Header -->
        <Border Grid.Row="0" Background="#1E293B" BorderBrush="#334155" BorderThickness="1" CornerRadius="8" Padding="16" Margin="0,0,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <iconPacks:PackIconMaterialDesign Kind="Camera" Width="20" Height="20" Foreground="#3B82F6" Margin="0,0,8,0"/>
                    <TextBlock Text="视觉检测(水星相机 + Halcon)" FontSize="16" FontWeight="SemiBold" Foreground="White"/>
                </StackPanel>
                
                <Button Grid.Column="2" Style="{StaticResource SecondaryButton}">
                    <StackPanel Orientation="Horizontal">
                        <iconPacks:PackIconMaterialDesign Kind="Refresh" Width="14" Height="14" Margin="0,0,6,0"/>
                        <TextBlock Text="重新枚举相机" FontSize="12"/>
                    </StackPanel>
                </Button>
            </Grid>
        </Border>
        
        <!-- Main Content -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="320"/>
            </Grid.ColumnDefinitions>
            
            <!-- Left - Camera Feed -->
            <Border Grid.Column="0" Background="#1E293B" BorderBrush="#334155" BorderThickness="1" CornerRadius="8" Margin="0,0,8,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    
                    <!-- Camera Info Bar -->
                    <Border Grid.Row="0" Background="#0F172A" BorderBrush="#334155" BorderThickness="0,0,0,1" Padding="8">
                        <Grid>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                                <Ellipse Width="6" Height="6" Fill="#10B981" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                <TextBlock Text="MER-134-90GM-P" FontSize="11" Foreground="#94A3B8"/>
                            </StackPanel>
                            <TextBlock Text="1920x1080 | Mono8 | 25 FPS" FontSize="11" Foreground="#94A3B8" HorizontalAlignment="Right"/>
                        </Grid>
                    </Border>
                    
                    <!-- Camera Feed Area -->
                    <Border Grid.Row="1" Background="Black">
                        <Grid>
                            <TextBlock Text="[相机实时画面区域]" Foreground="#334155" FontSize="14" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            
                            <!-- Halcon Overlay - Success -->
                            <Border Width="160" Height="100" BorderBrush="#10B981" BorderThickness="2" Background="#10B98110" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="-80,-40,0,0">
                                <Grid>
                                    <Line X1="0" Y1="50" X2="160" Y2="50" Stroke="#10B981" StrokeThickness="1"/>
                                    <Line X1="80" Y1="0" X2="80" Y2="100" Stroke="#10B981" StrokeThickness="1"/>
                                    <Border Background="#10B981" CornerRadius="2" Padding="4,2" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="0,-20,0,0">
                                        <TextBlock Text="Score: 0.982" FontSize="10" Foreground="Black" FontWeight="Bold" FontFamily="Consolas"/>
                                    </Border>
                                    <Border Background="#10B981" CornerRadius="2" Padding="4,2" HorizontalAlignment="Left" VerticalAlignment="Bottom" Margin="0,0,0,-20">
                                        <TextBlock Text="X:452 Y:388 A:12.5°" FontSize="10" Foreground="Black" FontWeight="Bold" FontFamily="Consolas"/>
                                    </Border>
                                </Grid>
                            </Border>
                            
                            <!-- Halcon Overlay - Fail -->
                            <Border Width="80" Height="80" BorderBrush="#EF4444" BorderThickness="2" Background="#EF444410" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="120,-80,0,0">
                                <Grid>
                                    <Line X1="0" Y1="40" X2="80" Y2="40" Stroke="#EF4444" StrokeThickness="1"/>
                                    <Line X1="40" Y1="0" X2="40" Y2="80" Stroke="#EF4444" StrokeThickness="1"/>
                                    <Border Background="#EF4444" CornerRadius="2" Padding="4,2" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="0,-20,0,0">
                                        <TextBlock Text="Score: 0.412" FontSize="10" Foreground="White" FontWeight="Bold" FontFamily="Consolas"/>
                                    </Border>
                                </Grid>
                            </Border>
                        </Grid>
                    </Border>
                    
                    <!-- Control Buttons -->
                    <Border Grid.Row="2" Background="#1E293B" BorderBrush="#334155" BorderThickness="0,1,0,0" Padding="12">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <Button Style="{StaticResource ActionButton}" Margin="0,0,8,0">
                                <StackPanel Orientation="Horizontal">
                                    <iconPacks:PackIconMaterialDesign Kind="PlayArrow" Width="16" Height="16" Margin="0,0,6,0"/>
                                    <TextBlock Text="连续采集" FontSize="12"/>
                                </StackPanel>
                            </Button>
                            <Button Style="{StaticResource SecondaryButton}" Margin="0,0,8,0">
                                <StackPanel Orientation="Horizontal">
                                    <iconPacks:PackIconMaterialDesign Kind="Stop" Width="16" Height="16" Margin="0,0,6,0"/>
                                    <TextBlock Text="停止采集" FontSize="12"/>
                                </StackPanel>
                            </Button>
                            <Button Style="{StaticResource SecondaryButton}">
                                <StackPanel Orientation="Horizontal">
                                    <iconPacks:PackIconMaterialDesign Kind="GpsFixed" Width="16" Height="16" Margin="0,0,6,0"/>
                                    <TextBlock Text="单次匹配" FontSize="12"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>
            
            <!-- Right - Params -->
            <Border Grid.Column="1" Background="#1E293B" BorderBrush="#334155" BorderThickness="1" CornerRadius="8" Margin="8,0,0,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    
                    <!-- Camera Params -->
                    <Border Grid.Row="0" BorderBrush="#334155" BorderThickness="0,0,0,1" Padding="12">
                        <TextBlock Text="相机参数 (Camera)" FontSize="13" FontWeight="Medium" Foreground="#CBD5E1"/>
                    </Border>
                    
                    <StackPanel Grid.Row="1" Margin="12">
                        <!-- Exposure -->
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="曝光时间 (Exposure)" FontSize="11" Foreground="#94A3B8"/>
                            <TextBlock Grid.Column="1" Text="1000 us" FontSize="11" Foreground="#3B82F6" FontFamily="Consolas"/>
                        </Grid>
                        <Slider Minimum="10" Maximum="10000" Value="1000" Background="#334155" Foreground="#3B82F6" Margin="0,0,0,16"/>
                        
                        <!-- Gain -->
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="增益 (Gain)" FontSize="11" Foreground="#94A3B8"/>
                            <TextBlock Grid.Column="1" Text="6.0 dB" FontSize="11" Foreground="#3B82F6" FontFamily="Consolas"/>
                        </Grid>
                        <Slider Minimum="0" Maximum="24" Value="6" Background="#334155" Foreground="#3B82F6" Margin="0,0,0,16"/>
                        
                        <!-- Trigger Mode -->
                        <TextBlock Text="触发模式" FontSize="11" Foreground="#94A3B8" Margin="0,0,0,8"/>
                        <ComboBox Background="#0F172A" Foreground="#E2E8F0" BorderBrush="#475569" SelectedIndex="0">
                            <ComboBoxItem Content="连续采集 (Continuous)"/>
                            <ComboBoxItem Content="软触发 (Software)"/>
                            <ComboBoxItem Content="硬触发 (Hardware)"/>
                        </ComboBox>
                    </StackPanel>
                    
                    <!-- Halcon Params -->
                    <Border Grid.Row="2" BorderBrush="#334155" BorderThickness="0,1,0,1" Padding="12" Margin="0,8,0,0">
                        <TextBlock Text="算法参数 (Halcon)" FontSize="13" FontWeight="Medium" Foreground="#CBD5E1"/>
                    </Border>
                    
                    <StackPanel Grid.Row="3" Margin="12">
                        <!-- Current Template -->
                        <Border Background="#0F172A" BorderBrush="#334155" BorderThickness="1" CornerRadius="4" Padding="8" Margin="0,0,0,12">
                            <Grid>
                                <TextBlock Text="当前模板" FontSize="11" Foreground="#64748B"/>
                                <TextBlock Text="Tpl_PartA_001.shm" FontSize="11" Foreground="#E2E8F0" FontFamily="Consolas" HorizontalAlignment="Right"/>
                            </Grid>
                        </Border>
                        
                        <!-- Match Score -->
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="匹配分数阈值" FontSize="11" Foreground="#94A3B8"/>
                            <TextBlock Grid.Column="1" Text="0.70" FontSize="11" Foreground="#10B981" FontFamily="Consolas"/>
                        </Grid>
                        <Slider Minimum="0" Maximum="100" Value="70" Background="#334155" Foreground="#10B981" Margin="0,0,0,16"/>
                        
                        <!-- Save Button -->
                        <Button Style="{StaticResource SecondaryButton}" HorizontalAlignment="Stretch">
                            <StackPanel Orientation="Horizontal">
                                <iconPacks:PackIconMaterialDesign Kind="ContentCopy" Width="14" Height="14" Margin="0,0,6,0"/>
                                <TextBlock Text="保存当前参数" FontSize="12"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Page>