<Page x:Class="VisionMotionControl.Views.Pages.CadParsePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
      Background="#0B0F19">
    
    <Page.Resources>
        <Style x:Key="ActionButton" TargetType="Button">
            <Setter Property="Background" Value="#3B82F6"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#60A5FA"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
        <Style x:Key="SecondaryButton" TargetType="Button">
            <Setter Property="Background" Value="#475569"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#64748B"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>
    
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        
        <!-- Header -->
        <Border Grid.Row="0" Background="#1E293B" BorderBrush="#334155" BorderThickness="1" CornerRadius="8" Padding="16" Margin="0,0,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <iconPacks:PackIconMaterialDesign Kind="Map" Width="20" Height="20" Foreground="#3B82F6" Margin="0,0,8,0"/>
                    <TextBlock Text="CAD图纸解析 (DXF)" FontSize="16" FontWeight="SemiBold" Foreground="White"/>
                </StackPanel>
                
                <Button Grid.Column="2" Style="{StaticResource SecondaryButton}">
                    <StackPanel Orientation="Horizontal">
                        <iconPacks:PackIconMaterialDesign Kind="Upload" Width="14" Height="14" Margin="0,0,6,0"/>
                        <TextBlock Text="导入 DXF" FontSize="12"/>
                    </StackPanel>
                </Button>
            </Grid>
        </Border>
        
        <!-- Main Content -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="320"/>
            </Grid.ColumnDefinitions>
            
            <!-- Left - CAD View -->
            <Border Grid.Column="0" Background="#1E293B" BorderBrush="#334155" BorderThickness="1" CornerRadius="8" Margin="0,0,8,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    
                    <!-- File Info -->
                    <Border Grid.Row="0" Background="#0F172A" BorderBrush="#334155" BorderThickness="0,0,0,1" Padding="8">
                        <Grid>
                            <TextBlock Text="当前图纸: Part_Layout_v2.dxf" FontSize="11" Foreground="#94A3B8" HorizontalAlignment="Left"/>
                            <TextBlock Text="已解析图元: 124直线, 48圆弧, 12点位" FontSize="11" Foreground="#94A3B8" HorizontalAlignment="Right"/>
                        </Grid>
                    </Border>
                    
                    <!-- CAD Canvas -->
                    <Border Grid.Row="1" Background="#0A0F18">
                        <Grid>
                            <!-- Grid Background -->
                            <Canvas>
                                <Canvas.Background>
                                    <DrawingBrush TileMode="Tile" Viewport="0,0,40,40" ViewportUnits="Absolute">
                                        <DrawingBrush.Drawing>
                                            <GeometryDrawing Brush="Transparent">
                                                <GeometryDrawing.Pen>
                                                    <Pen Brush="#FFFFFF0D" Thickness="1"/>
                                                </GeometryDrawing.Pen>
                                                <GeometryDrawing.Geometry>
                                                    <RectangleGeometry Rect="0,0,40,40"/>
                                                </GeometryDrawing.Geometry>
                                            </GeometryDrawing>
                                        </DrawingBrush.Drawing>
                                    </DrawingBrush>
                                </Canvas.Background>
                            </Canvas>
                            
                            <!-- Trajectory Path -->
                            <Canvas Margin="32">
                                <Path Stroke="#3B82F6" StrokeThickness="2" StrokeDashArray="5,5">
                                    <Path.Data>
                                        <PathGeometry>
                                            <PathFigure StartPoint="100,100">
                                                <LineSegment Point="300,100"/>
                                                <LineSegment Point="300,300"/>
                                                <LineSegment Point="100,300"/>
                                                <LineSegment Point="100,100"/>
                                            </PathFigure>
                                        </PathGeometry>
                                    </Path.Data>
                                    <Path.Effect>
                                        <DropShadowEffect Color="#3B82F6" BlurRadius="4" ShadowDepth="0"/>
                                    </Path.Effect>
                                </Path>
                                
                                <!-- Points -->
                                <Ellipse Canvas.Left="96" Canvas.Top="96" Width="8" Height="8" Fill="#EF4444"/>
                                <Ellipse Canvas.Left="296" Canvas.Top="96" Width="8" Height="8" Fill="#EF4444"/>
                                <Ellipse Canvas.Left="296" Canvas.Top="296" Width="8" Height="8" Fill="#EF4444"/>
                                <Ellipse Canvas.Left="96" Canvas.Top="296" Width="8" Height="8" Fill="#EF4444"/>
                            </Canvas>
                            
                            <TextBlock Text="[CAD图纸预览区域]" Foreground="#334155" FontSize="14" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Grid>
                    </Border>
                </Grid>
            </Border>
            
            <!-- Right - Trajectory -->
            <Border Grid.Column="1" Background="#1E293B" BorderBrush="#334155" BorderThickness="1" CornerRadius="8" Margin="8,0,0,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    
                    <Border Grid.Row="0" BorderBrush="#334155" BorderThickness="0,0,0,1" Padding="12">
                        <TextBlock Text="轨迹下发" FontSize="13" FontWeight="Medium" Foreground="#CBD5E1"/>
                    </Border>
                    
                    <StackPanel Grid.Row="1" Margin="12">
                        <!-- Points List -->
                        <TextBlock Text="提取的运动点位(前5个)" FontSize="11" Foreground="#94A3B8" Margin="0,0,0,8"/>
                        <Border Background="#0B0F19" BorderBrush="#334155" BorderThickness="1" CornerRadius="4" Padding="12" Height="200">
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <StackPanel>
                                    <Grid Margin="0,0,0,6">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="32"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="P1" FontSize="12" Foreground="#64748B" FontFamily="Consolas"/>
                                        <TextBlock Grid.Column="1" Text="X: 120.00" FontSize="12" Foreground="#CBD5E1" FontFamily="Consolas"/>
                                        <TextBlock Grid.Column="2" Text="Y: 45.00" FontSize="12" Foreground="#CBD5E1" FontFamily="Consolas"/>
                                    </Grid>
                                    <Grid Margin="0,0,0,6">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="32"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="P2" FontSize="12" Foreground="#64748B" FontFamily="Consolas"/>
                                        <TextBlock Grid.Column="1" Text="X: 240.00" FontSize="12" Foreground="#CBD5E1" FontFamily="Consolas"/>
                                        <TextBlock Grid.Column="2" Text="Y: 45.00" FontSize="12" Foreground="#CBD5E1" FontFamily="Consolas"/>
                                    </Grid>
                                    <Grid Margin="0,0,0,6">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="32"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="P3" FontSize="12" Foreground="#64748B" FontFamily="Consolas"/>
                                        <TextBlock Grid.Column="1" Text="X: 240.00" FontSize="12" Foreground="#CBD5E1" FontFamily="Consolas"/>
                                        <TextBlock Grid.Column="2" Text="Y: 180.00" FontSize="12" Foreground="#CBD5E1" FontFamily="Consolas"/>
                                    </Grid>
                                    <Grid Margin="0,0,0,6">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="32"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="P4" FontSize="12" Foreground="#64748B" FontFamily="Consolas"/>
                                        <TextBlock Grid.Column="1" Text="X: 120.00" FontSize="12" Foreground="#CBD5E1" FontFamily="Consolas"/>
                                        <TextBlock Grid.Column="2" Text="Y: 180.00" FontSize="12" Foreground="#CBD5E1" FontFamily="Consolas"/>
                                    </Grid>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="32"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="P5" FontSize="12" Foreground="#64748B" FontFamily="Consolas"/>
                                        <TextBlock Grid.Column="1" Text="X: 120.00" FontSize="12" Foreground="#CBD5E1" FontFamily="Consolas"/>
                                        <TextBlock Grid.Column="2" Text="Y: 45.00" FontSize="12" Foreground="#CBD5E1" FontFamily="Consolas"/>
                                    </Grid>
                                </StackPanel>
                            </ScrollViewer>
                        </Border>

                        <!-- Offset Calibration -->
                        <TextBlock Text="坐标校准补偿" FontSize="11" Foreground="#94A3B8" Margin="0,16,0,8"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,4,0">
                                <TextBlock Text="X偏移" FontSize="11" Foreground="#64748B" Margin="0,0,0,4"/>
                                <TextBox Text="0.00" Background="#0F172A" Foreground="#E2E8F0" BorderBrush="#475569" FontFamily="Consolas" Padding="6,4"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Margin="4,0,0,0">
                                <TextBlock Text="Y偏移" FontSize="11" Foreground="#64748B" Margin="0,0,0,4"/>
                                <TextBox Text="0.00" Background="#0F172A" Foreground="#E2E8F0" BorderBrush="#475569" FontFamily="Consolas" Padding="6,4"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                    
                    <StackPanel Grid.Row="2" Margin="12,0,12,12">
                        <Button Style="{StaticResource ActionButton}" Margin="0,0,0,8">
                            <StackPanel Orientation="Horizontal">
                                <iconPacks:PackIconMaterialDesign Kind="PlayArrow" Width="16" Height="16" Margin="0,0,6,0"/>
                                <TextBlock Text="一键下发至运动卡" FontSize="12"/>
                            </StackPanel>
                        </Button>
                        <Button Style="{StaticResource SecondaryButton}">
                            <StackPanel Orientation="Horizontal">
                                <iconPacks:PackIconMaterialDesign Kind="GpsFixed" Width="14" Height="14" Margin="0,0,6,0"/>
                                <TextBlock Text="空载模拟运行" FontSize="12"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Page>
