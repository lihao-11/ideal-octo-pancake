<Page x:Class="VisionMotionControl.Views.Pages.SystemConfigPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
      Background="#0B0F19">
    
    <Page.Resources>
        <Style x:Key="ActionButton" TargetType="Button">
            <Setter Property="Background" Value="#3B82F6"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#60A5FA"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
        <Style x:Key="SecondaryButton" TargetType="Button">
            <Setter Property="Background" Value="#475569"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#64748B"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
        <Style x:Key="ConfigCard" TargetType="Border">
            <Setter Property="Background" Value="#1E293B"/>
            <Setter Property="BorderBrush" Value="#334155"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
        </Style>
        
        <Style x:Key="ConfigSectionHeader" TargetType="Border">
            <Setter Property="Background" Value="#1E293B"/>
            <Setter Property="BorderBrush" Value="#334155"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="Padding" Value="12"/>
        </Style>
    </Page.Resources>
    
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        
        <!-- Header -->
        <Border Grid.Row="0" Background="#1E293B" BorderBrush="#334155" BorderThickness="1" CornerRadius="8" Padding="16" Margin="0,0,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <iconPacks:PackIconMaterialDesign Kind="Settings" Width="20" Height="20" Foreground="#3B82F6" Margin="0,0,8,0"/>
                    <TextBlock Text="系统及硬件配置" FontSize="16" FontWeight="SemiBold" Foreground="White"/>
                </StackPanel>
                
                <Button Grid.Column="2" Style="{StaticResource ActionButton}">
                    <StackPanel Orientation="Horizontal">
                        <iconPacks:PackIconMaterialDesign Kind="ContentCopy" Width="16" Height="16" Margin="0,0,6,0"/>
                        <TextBlock Text="保存所有配置" FontSize="12"/>
                    </StackPanel>
                </Button>
            </Grid>
        </Border>
        
        <!-- Config Cards -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <UniformGrid Columns="2" Margin="0,0,-8,0">
                
                <!-- Hardware Config -->
                <Border Style="{StaticResource ConfigCard}" Margin="0,0,8,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        
                        <Border Style="{StaticResource ConfigSectionHeader}">
                            <StackPanel Orientation="Horizontal">
                                <iconPacks:PackIconMaterialDesign Kind="Usb" Width="16" Height="16" Foreground="#10B981" Margin="0,0,8,0"/>
                                <TextBlock Text="硬件通信参数 (Hardware)" FontSize="13" FontWeight="Medium" Foreground="#E2E8F0"/>
                            </StackPanel>
                        </Border>
                        
                        <Grid Grid.Row="1" Margin="16">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- ECI1408 分组标题 -->
                            <TextBlock Grid.Row="0" Text="正运动 ECI1408 运动卡" FontSize="11" FontWeight="Bold" Foreground="#64748B" Margin="0,0,0,10"/>

                            <!-- IP地址 + 心跳检测间隔 并排 -->
                            <Grid Grid.Row="1" Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <!-- 左：IP地址 -->
                                <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                    <TextBlock Text="IP 地址" FontSize="11" Foreground="#94A3B8" Margin="0,0,0,4"/>
                                    <TextBox Text="192.168.1.200" Background="#0F172A" Foreground="#E2E8F0" BorderBrush="#475569" FontFamily="Consolas" Padding="8,4"/>
                                </StackPanel>
                                <!-- 右：心跳检测间隔 -->
                                <StackPanel Grid.Column="1" Margin="8,0,0,0">
                                    <TextBlock Text="心跳检测间隔 (ms)" FontSize="11" Foreground="#94A3B8" Margin="0,0,0,4"/>
                                    <TextBox Text="2000" Background="#0F172A" Foreground="#E2E8F0" BorderBrush="#475569" FontFamily="Consolas" Padding="8,4"/>
                                </StackPanel>
                            </Grid>

                            <!-- 分隔线 -->
                            <Rectangle Grid.Row="2" Height="1" Fill="#334155" Margin="0,0,0,12"/>

                            <!-- Camera 分组标题 -->
                            <TextBlock Grid.Row="3" Text="水星工业相机 (GigE)" FontSize="11" FontWeight="Bold" Foreground="#64748B" Margin="0,0,0,10"/>

                            <!-- 相机IP + 默认心跳 并排 -->
                            <Grid Grid.Row="4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <!-- 左：相机IP -->
                                <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                    <TextBlock Text="IP 地址" FontSize="11" Foreground="#94A3B8" Margin="0,0,0,4"/>
                                    <TextBox Text="192.168.1.201" Background="#0F172A" Foreground="#E2E8F0" BorderBrush="#475569" FontFamily="Consolas" Padding="8,4"/>
                                </StackPanel>
                                <!-- 右：默认心跳 -->
                                <StackPanel Grid.Column="1" Margin="8,0,0,0">
                                    <TextBlock Text="默认心跳 (ms)" FontSize="11" Foreground="#94A3B8" Margin="0,0,0,4"/>
                                    <TextBox Text="1000" Background="#0F172A" Foreground="#E2E8F0" BorderBrush="#475569" FontFamily="Consolas" Padding="8,4"/>
                                </StackPanel>
                            </Grid>
                        </Grid>
                    </Grid>
                </Border>
                
                <!-- MQTT Config -->
                <Border Style="{StaticResource ConfigCard}" Margin="8,0,0,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        
                        <Border Style="{StaticResource ConfigSectionHeader}">
                            <StackPanel Orientation="Horizontal">
                                <iconPacks:PackIconMaterialDesign Kind="Wifi" Width="16" Height="16" Foreground="#3B82F6" Margin="0,0,8,0"/>
                                <TextBlock Text="MQTT 远程监控参数" FontSize="13" FontWeight="Medium" Foreground="#E2E8F0"/>
                            </StackPanel>
                        </Border>
                        
                        <Grid Grid.Row="1" Margin="16">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- Broker IP + 端口 并排 -->
                            <Grid Grid.Row="0" Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <!-- 左：Broker IP -->
                                <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                    <TextBlock Text="Broker IP" FontSize="11" Foreground="#94A3B8" Margin="0,0,0,4"/>
                                    <TextBox Text="10.0.0.55" Background="#0F172A" Foreground="#E2E8F0" BorderBrush="#475569" FontFamily="Consolas" Padding="8,4"/>
                                </StackPanel>
                                <!-- 右：端口 -->
                                <StackPanel Grid.Column="1" Margin="8,0,0,0">
                                    <TextBlock Text="端口 (Port)" FontSize="11" Foreground="#94A3B8" Margin="0,0,0,4"/>
                                    <TextBox Text="1883" Background="#0F172A" Foreground="#E2E8F0" BorderBrush="#475569" FontFamily="Consolas" Padding="8,4"/>
                                </StackPanel>
                            </Grid>

                            <!-- 用户名 + 密码 并排 -->
                            <Grid Grid.Row="1" Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <!-- 左：用户名 -->
                                <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                    <TextBlock Text="用户名 (Username)" FontSize="11" Foreground="#94A3B8" Margin="0,0,0,4"/>
                                    <TextBox Text="admin_device_01" Background="#0F172A" Foreground="#E2E8F0" BorderBrush="#475569" FontFamily="Consolas" Padding="8,4"/>
                                </StackPanel>
                                <!-- 右：密码 -->
                                <StackPanel Grid.Column="1" Margin="8,0,0,0">
                                    <TextBlock Text="密码 (Password)" FontSize="11" Foreground="#94A3B8" Margin="0,0,0,4"/>
                                    <TextBox Text="********" Background="#0F172A" Foreground="#E2E8F0" BorderBrush="#475569" FontFamily="Consolas" Padding="8,4"/>
                                </StackPanel>
                            </Grid>

                            <!-- 分隔线 -->
                            <Rectangle Grid.Row="2" Height="1" Fill="#334155" Margin="0,0,0,12"/>

                            <!-- 状态上报主题 -->
                            <StackPanel Grid.Row="3" Margin="0,0,0,10">
                                <TextBlock Text="状态上报主题 (Publish Topic)" FontSize="11" Foreground="#94A3B8" Margin="0,0,0,4"/>
                                <TextBox Text="device/state/report" Background="#0F172A" Foreground="#E2E8F0" BorderBrush="#475569" FontFamily="Consolas" Padding="8,4"/>
                            </StackPanel>

                            <!-- 指令接收主题 -->
                            <StackPanel Grid.Row="4">
                                <TextBlock Text="指令接收主题 (Subscribe Topic)" FontSize="11" Foreground="#94A3B8" Margin="0,0,0,4"/>
                                <TextBox Text="device/command/receive" Background="#0F172A" Foreground="#E2E8F0" BorderBrush="#475569" FontFamily="Consolas" Padding="8,4"/>
                            </StackPanel>
                        </Grid>
                    </Grid>
                </Border>
                
                <!-- License -->
                <Border Style="{StaticResource ConfigCard}" Margin="0,0,8,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        
                        <Border Style="{StaticResource ConfigSectionHeader}">
                            <StackPanel Orientation="Horizontal">
                                <iconPacks:PackIconMaterialDesign Kind="Shield" Width="16" Height="16" Foreground="#F59E0B" Margin="0,0,8,0"/>
                                <TextBlock Text="软件授权管理 (License)" FontSize="13" FontWeight="Medium" Foreground="#E2E8F0"/>
                            </StackPanel>
                        </Border>
                        
                        <StackPanel Grid.Row="1" Margin="16">
                            <!-- License Status -->
                            <Border Background="#0F172A" BorderBrush="#334155" BorderThickness="1" CornerRadius="6" Padding="12" Margin="0,0,0,16">
                                <StackPanel Orientation="Horizontal">
                                    <Border Width="48" Height="48" Background="#10B98120" BorderBrush="#10B98140" BorderThickness="2" CornerRadius="24" Margin="0,0,12,0">
                                        <iconPacks:PackIconMaterialDesign Kind="Shield" Width="24" Height="24" Foreground="#10B981" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <StackPanel VerticalAlignment="Center">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="永久授权" FontSize="16" Foreground="#E2E8F0" FontWeight="Bold" Margin="0,0,8,0"/>
                                            <Border Background="#10B981" CornerRadius="10" Padding="6,2">
                                                <TextBlock Text="VALID" FontSize="9" Foreground="White" FontWeight="Bold"/>
                                            </Border>
                                        </StackPanel>
                                        <TextBlock Text="系统所有核心模块已解锁" FontSize="12" Foreground="#64748B" Margin="0,4,0,0"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                            
                            <!-- Machine Code -->
                            <TextBlock Text="设备唯一机器码 (Machine Code)" FontSize="11" Foreground="#94A3B8" Margin="0,0,0,4"/>
                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox Text="VM-8B2A-99F1-C34D" Background="#0F172A" Foreground="#94A3B8" BorderBrush="#475569" FontFamily="Consolas" Padding="8,4" IsReadOnly="True" Opacity="0.7"/>
                                <Button Grid.Column="1" Style="{StaticResource SecondaryButton}" Margin="8,0,0,0">
                                    <TextBlock Text="复制" FontSize="11"/>
                                </Button>
                            </Grid>
                            
                            <!-- License Key -->
                            <TextBlock Text="授权码 (License Key)" FontSize="11" Foreground="#94A3B8" Margin="0,0,0,4"/>
                            <TextBox Text="eyJ0eXBlIjoiUEVSTUFORU5UIiwibWFjaGluZSI6IlZNLThCMkEtOTlGMS1DMzREIn0=..." 
                                     Background="#0F172A" Foreground="#E2E8F0" BorderBrush="#475569" FontFamily="Consolas" 
                                     Padding="8,4" TextWrapping="Wrap" Height="60" AcceptsReturn="True"/>
                        </StackPanel>
                    </Grid>
                </Border>
                
                <!-- System Params -->
                <Border Style="{StaticResource ConfigCard}" Margin="8,0,0,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        
                        <Border Style="{StaticResource ConfigSectionHeader}">
                            <StackPanel Orientation="Horizontal">
                                <iconPacks:PackIconMaterialDesign Kind="Fingerprint" Width="16" Height="16" Foreground="#A855F7" Margin="0,0,8,0"/>
                                <TextBlock Text="系统全局参数" FontSize="13" FontWeight="Medium" Foreground="#E2E8F0"/>
                            </StackPanel>
                        </Border>
                        
                        <StackPanel Grid.Row="1" Margin="16">
                            <TextBlock Text="日志自动清理周期 (天)" FontSize="11" Foreground="#94A3B8" Margin="0,0,0,4"/>
                            <ComboBox Background="#0F172A" Foreground="#E2E8F0" BorderBrush="#475569" SelectedIndex="0" Margin="0,0,0,16">
                                <ComboBoxItem Content="30 天"/>
                                <ComboBoxItem Content="90 天"/>
                                <ComboBoxItem Content="180 天"/>
                                <ComboBoxItem Content="不清理"/>
                            </ComboBox>
                            
                            <!-- Toggle 1 -->
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                <Border Width="32" Height="16" Background="#3B82F6" CornerRadius="8" Padding="2" Margin="0,0,12,0">
                                    <Ellipse Width="12" Height="12" Fill="White" HorizontalAlignment="Right"/>
                                </Border>
                                <TextBlock Text="启动时自动连接硬件" FontSize="12" Foreground="#CBD5E1" VerticalAlignment="Center"/>
                            </StackPanel>
                            
                            <!-- Toggle 2 -->
                            <StackPanel Orientation="Horizontal">
                                <Border Width="32" Height="16" Background="#475569" CornerRadius="8" Padding="2" Margin="0,0,12,0">
                                    <Ellipse Width="12" Height="12" Fill="White" HorizontalAlignment="Left"/>
                                </Border>
                                <TextBlock Text="开启敏感操作二次确认 (急停、配方修改等)" FontSize="12" Foreground="#CBD5E1" VerticalAlignment="Center"/>
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                </Border>
                
            </UniformGrid>
        </ScrollViewer>
    </Grid>
</Page>
