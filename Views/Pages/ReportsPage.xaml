<Page x:Class="VisionMotionControl.Views.Pages.ReportsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
      Background="#0B0F19">
    
    <Page.Resources>
        <Style x:Key="ActionButton" TargetType="Button">
            <Setter Property="Background" Value="#3B82F6"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#60A5FA"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
        <Style x:Key="StatCard" TargetType="Border">
            <Setter Property="Background" Value="#1E293B"/>
            <Setter Property="BorderBrush" Value="#334155"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="16"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
        </Style>
    </Page.Resources>
    
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        
        <!-- Header -->
        <Border Grid.Row="0" Background="#1E293B" BorderBrush="#334155" BorderThickness="1" CornerRadius="8" Padding="16" Margin="0,0,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <iconPacks:PackIconMaterialDesign Kind="BarChart" Width="20" Height="20" Foreground="#3B82F6" Margin="0,0,8,0"/>
                    <TextBlock Text="数据统计与报表" FontSize="16" FontWeight="SemiBold" Foreground="White"/>
                </StackPanel>
                
                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <Border Background="#0F172A" BorderBrush="#475569" BorderThickness="1" CornerRadius="4" Padding="8,4" Margin="0,0,8,0">
                        <StackPanel Orientation="Horizontal">
                            <iconPacks:PackIconMaterialDesign Kind="AccessTime" Width="14" Height="14" Foreground="#94A3B8" Margin="0,0,6,0"/>
                            <TextBlock Text="今日" FontSize="12" Foreground="#CBD5E1"/>
                        </StackPanel>
                    </Border>
                    <Button Style="{StaticResource ActionButton}">
                        <StackPanel Orientation="Horizontal">
                            <iconPacks:PackIconMaterialDesign Kind="Download" Width="14" Height="14" Margin="0,0,6,0"/>
                            <TextBlock Text="导出 Excel" FontSize="12"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>
        
        <!-- Stat Cards -->
        <Grid Grid.Row="1" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            
            <Border Grid.Column="0" Style="{StaticResource StatCard}">
                <StackPanel>
                    <TextBlock Text="今日总产量" FontSize="12" Foreground="#94A3B8" Margin="0,0,0,8"/>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="848" FontSize="28" Foreground="#F1F5F9" FontWeight="Bold"/>
                        <TextBlock Text="件" FontSize="12" Foreground="#64748B" Margin="4,0,0,0" VerticalAlignment="Bottom"/>
                    </StackPanel>
                </StackPanel>
            </Border>
            
            <Border Grid.Column="1" Style="{StaticResource StatCard}">
                <StackPanel>
                    <TextBlock Text="视觉检测良率" FontSize="12" Foreground="#94A3B8" Margin="0,0,0,8"/>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="98.2" FontSize="28" Foreground="#F1F5F9" FontWeight="Bold"/>
                        <TextBlock Text="%" FontSize="12" Foreground="#64748B" Margin="4,0,0,0" VerticalAlignment="Bottom"/>
                    </StackPanel>
                    <TextBlock Text="+0.5% 较昨日" FontSize="11" Foreground="#10B981" Margin="0,4,0,0"/>
                </StackPanel>
            </Border>
            
            <Border Grid.Column="2" Style="{StaticResource StatCard}">
                <StackPanel>
                    <TextBlock Text="三轴运行总长" FontSize="12" Foreground="#94A3B8" Margin="0,0,0,8"/>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="12.5" FontSize="28" Foreground="#F1F5F9" FontWeight="Bold"/>
                        <TextBlock Text="km" FontSize="12" Foreground="#64748B" Margin="4,0,0,0" VerticalAlignment="Bottom"/>
                    </StackPanel>
                </StackPanel>
            </Border>
            
            <Border Grid.Column="3" Style="{StaticResource StatCard}" Margin="0">
                <StackPanel>
                    <TextBlock Text="设备报警次数" FontSize="12" Foreground="#94A3B8" Margin="0,0,0,8"/>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="2" FontSize="28" Foreground="#F1F5F9" FontWeight="Bold"/>
                        <TextBlock Text="次" FontSize="12" Foreground="#64748B" Margin="4,0,0,0" VerticalAlignment="Bottom"/>
                    </StackPanel>
                    <TextBlock Text="-1 较昨日" FontSize="11" Foreground="#10B981" Margin="0,4,0,0"/>
                </StackPanel>
            </Border>
        </Grid>
        
        <!-- Charts -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            
            <!-- Yield Chart -->
            <Border Grid.Column="0" Background="#1E293B" BorderBrush="#334155" BorderThickness="1" CornerRadius="8" Padding="16" Margin="0,0,8,0">
                <Grid>
                    <TextBlock Text="视觉检测产量与良品统计 (件)" FontSize="13" FontWeight="Medium" Foreground="#CBD5E1" Margin="0,0,0,12"/>
                    <Border Margin="0,28,0,0" Background="#0F172A" CornerRadius="6">
                        <Grid>
                            <TextBlock Text="[柱状图区域]" Foreground="#334155" FontSize="14" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            <!-- Placeholder bars -->
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="0,0,0,40">
                                <StackPanel Margin="8,0" VerticalAlignment="Bottom">
                                    <Border Width="24" Height="80" Background="#10B981" CornerRadius="4,4,0,0"/>
                                    <Border Width="24" Height="2" Background="#EF4444" CornerRadius="0" Margin="0,2,0,0"/>
                                    <TextBlock Text="08:00" FontSize="10" Foreground="#64748B" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                                </StackPanel>
                                <StackPanel Margin="8,0" VerticalAlignment="Bottom">
                                    <Border Width="24" Height="88" Background="#10B981" CornerRadius="4,4,0,0"/>
                                    <Border Width="24" Height="2" Background="#EF4444" CornerRadius="0" Margin="0,2,0,0"/>
                                    <TextBlock Text="09:00" FontSize="10" Foreground="#64748B" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                                </StackPanel>
                                <StackPanel Margin="8,0" VerticalAlignment="Bottom">
                                    <Border Width="24" Height="64" Background="#10B981" CornerRadius="4,4,0,0"/>
                                    <Border Width="24" Height="6" Background="#EF4444" CornerRadius="0" Margin="0,2,0,0"/>
                                    <TextBlock Text="10:00" FontSize="10" Foreground="#64748B" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                                </StackPanel>
                                <StackPanel Margin="8,0" VerticalAlignment="Bottom">
                                    <Border Width="24" Height="94" Background="#10B981" CornerRadius="4,4,0,0"/>
                                    <Border Width="24" Height="1" Background="#EF4444" CornerRadius="0" Margin="0,2,0,0"/>
                                    <TextBlock Text="11:00" FontSize="10" Foreground="#64748B" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                                </StackPanel>
                                <StackPanel Margin="8,0" VerticalAlignment="Bottom">
                                    <Border Width="24" Height="76" Background="#10B981" CornerRadius="4,4,0,0"/>
                                    <Border Width="24" Height="3" Background="#EF4444" CornerRadius="0" Margin="0,2,0,0"/>
                                    <TextBlock Text="12:00" FontSize="10" Foreground="#64748B" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                                </StackPanel>
                                <StackPanel Margin="8,0" VerticalAlignment="Bottom">
                                    <Border Width="24" Height="60" Background="#10B981" CornerRadius="4,4,0,0"/>
                                    <Border Width="24" Height="2" Background="#EF4444" CornerRadius="0" Margin="0,2,0,0"/>
                                    <TextBlock Text="13:00" FontSize="10" Foreground="#64748B" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                                </StackPanel>
                                <StackPanel Margin="8,0" VerticalAlignment="Bottom">
                                    <Border Width="24" Height="100" Background="#10B981" CornerRadius="4,4,0,0"/>
                                    <Border Width="24" Height="2" Background="#EF4444" CornerRadius="0" Margin="0,2,0,0"/>
                                    <TextBlock Text="14:00" FontSize="10" Foreground="#64748B" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                                </StackPanel>
                            </StackPanel>
                            <!-- Legend -->
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="0,0,0,12">
                                <StackPanel Orientation="Horizontal" Margin="0,0,16,0">
                                    <Ellipse Width="8" Height="8" Fill="#10B981" Margin="0,0,6,0"/>
                                    <TextBlock Text="良品" FontSize="11" Foreground="#94A3B8"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal">
                                    <Ellipse Width="8" Height="8" Fill="#EF4444" Margin="0,0,6,0"/>
                                    <TextBlock Text="不良" FontSize="11" Foreground="#94A3B8"/>
                                </StackPanel>
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>
            </Border>
            
            <!-- Load Chart -->
            <Border Grid.Column="1" Background="#1E293B" BorderBrush="#334155" BorderThickness="1" CornerRadius="8" Padding="16" Margin="8,0,0,0">
                <Grid>
                    <TextBlock Text="三轴负载趋势 (%)" FontSize="13" FontWeight="Medium" Foreground="#CBD5E1" Margin="0,0,0,12"/>
                    <Border Margin="0,28,0,0" Background="#0F172A" CornerRadius="6">
                        <Grid>
                            <TextBlock Text="[折线图区域]" Foreground="#334155" FontSize="14" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            <!-- Placeholder lines -->
                            <Canvas Margin="40,20,20,40">
                                <!-- X Axis Line -->
                                <Path Stroke="#3B82F6" StrokeThickness="2">
                                    <Path.Data>
                                        <PathGeometry>
                                            <PathFigure StartPoint="0,80">
                                                <LineSegment Point="60,60"/>
                                                <LineSegment Point="120,70"/>
                                                <LineSegment Point="180,50"/>
                                                <LineSegment Point="240,75"/>
                                                <LineSegment Point="300,55"/>
                                                <LineSegment Point="360,45"/>
                                            </PathFigure>
                                        </PathGeometry>
                                    </Path.Data>
                                </Path>
                                <!-- Y Axis Line -->
                                <Path Stroke="#10B981" StrokeThickness="2">
                                    <Path.Data>
                                        <PathGeometry>
                                            <PathFigure StartPoint="0,100">
                                                <LineSegment Point="60,80"/>
                                                <LineSegment Point="120,90"/>
                                                <LineSegment Point="180,70"/>
                                                <LineSegment Point="240,85"/>
                                                <LineSegment Point="300,65"/>
                                                <LineSegment Point="360,55"/>
                                            </PathFigure>
                                        </PathGeometry>
                                    </Path.Data>
                                </Path>
                                <!-- Z Axis Line -->
                                <Path Stroke="#F59E0B" StrokeThickness="2">
                                    <Path.Data>
                                        <PathGeometry>
                                            <PathFigure StartPoint="0,120">
                                                <LineSegment Point="60,110"/>
                                                <LineSegment Point="120,115"/>
                                                <LineSegment Point="180,105"/>
                                                <LineSegment Point="240,118"/>
                                                <LineSegment Point="300,100"/>
                                                <LineSegment Point="360,95"/>
                                            </PathFigure>
                                        </PathGeometry>
                                    </Path.Data>
                                </Path>
                            </Canvas>
                            <!-- X Labels -->
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="0,0,0,12">
                                <TextBlock Text="08:00" FontSize="10" Foreground="#64748B" Margin="20,0"/>
                                <TextBlock Text="09:00" FontSize="10" Foreground="#64748B" Margin="20,0"/>
                                <TextBlock Text="10:00" FontSize="10" Foreground="#64748B" Margin="20,0"/>
                                <TextBlock Text="11:00" FontSize="10" Foreground="#64748B" Margin="20,0"/>
                                <TextBlock Text="12:00" FontSize="10" Foreground="#64748B" Margin="20,0"/>
                                <TextBlock Text="13:00" FontSize="10" Foreground="#64748B" Margin="20,0"/>
                                <TextBlock Text="14:00" FontSize="10" Foreground="#64748B" Margin="20,0"/>
                            </StackPanel>
                            <!-- Legend -->
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,8,0,0">
                                <StackPanel Orientation="Horizontal" Margin="0,0,16,0">
                                    <Ellipse Width="8" Height="8" Fill="#3B82F6" Margin="0,0,6,0"/>
                                    <TextBlock Text="X轴负载" FontSize="11" Foreground="#94A3B8"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,16,0">
                                    <Ellipse Width="8" Height="8" Fill="#10B981" Margin="0,0,6,0"/>
                                    <TextBlock Text="Y轴负载" FontSize="11" Foreground="#94A3B8"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal">
                                    <Ellipse Width="8" Height="8" Fill="#F59E0B" Margin="0,0,6,0"/>
                                    <TextBlock Text="Z轴负载" FontSize="11" Foreground="#94A3B8"/>
                                </StackPanel>
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Page>
