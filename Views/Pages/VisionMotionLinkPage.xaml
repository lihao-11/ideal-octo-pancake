<Page x:Class="VisionMotionControl.Views.Pages.VisionMotionLinkPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
      Background="#0B0F19">
    
    <Page.Resources>
        <Style x:Key="ActionButton" TargetType="Button">
            <Setter Property="Background" Value="#3B82F6"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#60A5FA"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
        <Style x:Key="DangerButton" TargetType="Button">
            <Setter Property="Background" Value="#EF4444"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#F87171"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
        <Style x:Key="StepCircle" TargetType="Border">
            <Setter Property="Width" Value="40"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="CornerRadius" Value="20"/>
            <Setter Property="BorderThickness" Value="2"/>
        </Style>
    </Page.Resources>
    
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        
        <!-- Header -->
        <Border Grid.Row="0" Background="#1E293B" BorderBrush="#334155" BorderThickness="1" CornerRadius="8" Padding="16" Margin="0,0,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <iconPacks:PackIconMaterialDesign Kind="Bolt" Width="20" Height="20" Foreground="#F59E0B" Margin="0,0,8,0"/>
                    <TextBlock Text="视运联动控制 (主监控)" FontSize="16" FontWeight="SemiBold" Foreground="White"/>
                    <Rectangle Width="1" Height="20" Fill="#334155" Margin="16,0"/>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="当前联动配方:" FontSize="13" Foreground="#94A3B8" Margin="0,0,8,0"/>
                        <Border Background="#10B98120" BorderBrush="#10B98140" BorderThickness="1" CornerRadius="4" Padding="8,2">
                            <TextBlock Text="Task_Assembly_A01" FontSize="13" Foreground="#10B981" FontFamily="Consolas"/>
                        </Border>
                    </StackPanel>
                </StackPanel>
                
                <Button Grid.Column="2" Style="{StaticResource ActionButton}" Background="#10B981">
                    <StackPanel Orientation="Horizontal">
                        <iconPacks:PackIconMaterialDesign Kind="PlayArrow" Width="16" Height="16" Margin="0,0,6,0"/>
                        <TextBlock Text="启动自动运行" FontWeight="Bold"/>
                    </StackPanel>
                </Button>
            </Grid>
        </Border>
        
        <!-- Main Content -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="7*"/>
                <ColumnDefinition Width="5*"/>
            </Grid.ColumnDefinitions>
            
            <!-- Left Column -->
            <Grid Grid.Column="0" Margin="0,0,8,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                
                <!-- Live View -->
                <Border Grid.Row="0" Background="#1E293B" BorderBrush="#334155" BorderThickness="1" CornerRadius="8" Margin="0,0,0,8">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        
                        <Border Grid.Row="0" Background="#0F172A" BorderBrush="#334155" BorderThickness="0,0,0,1" Padding="8">
                            <Grid>
                                <TextBlock Text="实时联动监控视图" FontSize="12" Foreground="#94A3B8" HorizontalAlignment="Left"/>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                    <Ellipse Width="6" Height="6" Fill="#10B981" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="System Running" FontSize="12" Foreground="#10B981"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                        
                        <Border Grid.Row="1" Background="Black">
                            <Grid>
                                <TextBlock Text="[相机实时画面区域]" Foreground="#334155" FontSize="14" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                
                                <!-- Target Overlay -->
                                <Border Width="120" Height="120" BorderBrush="#F59E0B" BorderThickness="2" Background="#F59E0B10" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="80,40,0,0">
                                    <Grid>
                                        <Ellipse Width="16" Height="16" Stroke="#F59E0B" StrokeThickness="2" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        <Border Background="#F59E0B" CornerRadius="2" Padding="4,2" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="0,-24,0,0">
                                            <TextBlock Text="TARGET: X=120 Y=45" FontSize="10" Foreground="Black" FontWeight="Bold" FontFamily="Consolas"/>
                                        </Border>
                                    </Grid>
                                </Border>
                                
                                <!-- Robot Position -->
                                <Grid HorizontalAlignment="Left" VerticalAlignment="Top" Margin="60,60,0,0">
                                    <Ellipse Width="24" Height="24" Stroke="#3B82F6" StrokeThickness="2" Fill="#3B82F620"/>
                                    <Ellipse Width="6" Height="6" Fill="#3B82F6" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    <Border Background="#3B82F6" CornerRadius="2" Padding="4,2" Margin="0,28,0,0" HorizontalAlignment="Left">
                                        <TextBlock Text="ROBOT: X=80 Y=20" FontSize="10" Foreground="White" FontWeight="Bold" FontFamily="Consolas"/>
                                    </Border>
                                </Grid>
                            </Grid>
                        </Border>
                        
                        <Border Grid.Row="2" Height="3" Background="#334155">
                            <Border Width="100" Height="3" Background="#10B981" HorizontalAlignment="Left">
                                <Border.Triggers>
                                    <EventTrigger RoutedEvent="Loaded">
                                        <BeginStoryboard>
                                            <Storyboard RepeatBehavior="Forever">
                                                <DoubleAnimation Storyboard.TargetProperty="(Canvas.Left)" From="-100" To="800" Duration="0:0:2"/>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </EventTrigger>
                                </Border.Triggers>
                            </Border>
                        </Border>
                    </Grid>
                </Border>
                
                <!-- Coordinate Transform -->
                <Border Grid.Row="1" Background="#1E293B" BorderBrush="#334155" BorderThickness="1" CornerRadius="8" Padding="12" Height="180">
                    <Grid>
                        <TextBlock Text="坐标转换与补偿矩阵" FontSize="13" FontWeight="Medium" Foreground="#CBD5E1" Margin="0,0,0,8"/>
                        <Grid Margin="0,28,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            
                            <Border Grid.Column="0" Background="#0F172A" BorderBrush="#334155" BorderThickness="1" CornerRadius="6" Padding="8" Margin="0,0,4,0">
                                <StackPanel>
                                    <TextBlock Text="视觉原始坐标 (Pixel)" FontSize="11" Foreground="#64748B" Margin="0,0,0,8"/>
                                    <TextBlock Text="X: 1250" FontSize="18" Foreground="#E2E8F0" FontFamily="Consolas" FontWeight="SemiBold"/>
                                    <TextBlock Text="Y: 864" FontSize="18" Foreground="#E2E8F0" FontFamily="Consolas" FontWeight="SemiBold"/>
                                </StackPanel>
                            </Border>
                            
                            <Border Grid.Column="1" Background="#0F172A" BorderBrush="#334155" BorderThickness="1" CornerRadius="6" Padding="8" Margin="4,0">
                                <Grid>
                                    <iconPacks:PackIconMaterialDesign Kind="ArrowRight" Width="16" Height="16" Foreground="#475569" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="-20,0,0,0"/>
                                    <StackPanel>
                                        <TextBlock Text="标定补偿 (mm)" FontSize="11" Foreground="#64748B" Margin="0,0,0,8"/>
                                        <TextBlock Text="ΔX: +0.025" FontSize="13" Foreground="#F59E0B" FontFamily="Consolas"/>
                                        <TextBlock Text="ΔY: -0.012" FontSize="13" Foreground="#F59E0B" FontFamily="Consolas" Margin="0,2,0,0"/>
                                        <TextBlock Text="Δθ: +1.5°" FontSize="13" Foreground="#F59E0B" FontFamily="Consolas" Margin="0,2,0,0"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                            
                            <Border Grid.Column="2" Background="#0F172A" BorderBrush="#334155" BorderThickness="1" CornerRadius="6" Padding="8" Margin="4,0,0,0">
                                <Grid>
                                    <iconPacks:PackIconMaterialDesign Kind="ArrowRight" Width="16" Height="16" Foreground="#475569" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="-20,0,0,0"/>
                                    <StackPanel>
                                        <TextBlock Text="目标机械坐标 (mm)" FontSize="11" Foreground="#64748B" Margin="0,0,0,8"/>
                                        <TextBlock Text="X: 125.045" FontSize="18" Foreground="#10B981" FontFamily="Consolas" FontWeight="SemiBold"/>
                                        <TextBlock Text="Y: 45.002" FontSize="18" Foreground="#10B981" FontFamily="Consolas" FontWeight="SemiBold"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </Grid>
                    </Grid>
                </Border>
            </Grid>
            
            <!-- Right Column -->
            <Grid Grid.Column="1" Margin="8,0,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                
                <!-- Steps -->
                <Border Grid.Row="0" Background="#1E293B" BorderBrush="#334155" BorderThickness="1" CornerRadius="8" Padding="16" Margin="0,0,0,8">
                    <Grid>
                        <TextBlock Text="联动流程执行监控" FontSize="13" FontWeight="Medium" Foreground="#CBD5E1" Margin="0,0,0,12"/>
                        <StackPanel Margin="0,28,0,0">
                            <!-- Step 1 -->
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Border Style="{StaticResource StepCircle}" Background="#10B98120" BorderBrush="#10B981" Grid.Column="0" Margin="0,0,12,0">
                                    <iconPacks:PackIconMaterialDesign Kind="Check" Width="20" Height="20" Foreground="#10B981" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="等待触发信号" FontSize="13" FontWeight="Bold" Foreground="#E2E8F0"/>
                                    <TextBlock Text="等待外部IO或软触发" FontSize="11" Foreground="#64748B"/>
                                </StackPanel>
                                <Rectangle Grid.Column="0" Width="2" Height="16" Fill="#10B981" HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="0,0,0,-16"/>
                            </Grid>
                            
                            <!-- Step 2 -->
                            <Grid Margin="0,8,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Border Style="{StaticResource StepCircle}" Background="#3B82F620" BorderBrush="#3B82F6" Grid.Column="0" Margin="0,0,12,0">
                                    <iconPacks:PackIconMaterialDesign Kind="Camera" Width="20" Height="20" Foreground="#3B82F6" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="相机图像采集" FontSize="13" FontWeight="Bold" Foreground="#3B82F6"/>
                                    <TextBlock Text="水星相机抓取单帧" FontSize="11" Foreground="#64748B"/>
                                </StackPanel>
                                <iconPacks:PackIconMaterialDesign Grid.Column="2" Kind="Cached" Width="16" Height="16" Foreground="#3B82F6" Margin="0,0,8,0">
                                    <iconPacks:PackIconMaterialDesign.RenderTransform>
                                        <RotateTransform CenterX="8" CenterY="8"/>
                                    </iconPacks:PackIconMaterialDesign.RenderTransform>
                                    <iconPacks:PackIconMaterialDesign.Triggers>
                                        <EventTrigger RoutedEvent="Loaded">
                                            <BeginStoryboard>
                                                <Storyboard RepeatBehavior="Forever">
                                                    <DoubleAnimation Storyboard.TargetProperty="RenderTransform.Angle" From="0" To="360" Duration="0:0:1"/>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </EventTrigger>
                                    </iconPacks:PackIconMaterialDesign.Triggers>
                                </iconPacks:PackIconMaterialDesign>
                                <Rectangle Grid.Column="0" Width="2" Height="16" Fill="#334155" HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="0,0,0,-16"/>
                            </Grid>
                            
                            <!-- Step 3 -->
                            <Grid Margin="0,8,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Border Style="{StaticResource StepCircle}" Background="#1E293B" BorderBrush="#475569" Grid.Column="0" Margin="0,0,12,0">
                                    <iconPacks:PackIconMaterialDesign Kind="Settings" Width="20" Height="20" Foreground="#64748B" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="视觉算法匹配" FontSize="13" FontWeight="Bold" Foreground="#64748B"/>
                                    <TextBlock Text="Halcon 亚像素模板匹配" FontSize="11" Foreground="#64748B"/>
                                </StackPanel>
                                <Rectangle Grid.Column="0" Width="2" Height="16" Fill="#334155" HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="0,0,0,-16"/>
                            </Grid>
                            
                            <!-- Step 4 -->
                            <Grid Margin="0,8,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Border Style="{StaticResource StepCircle}" Background="#1E293B" BorderBrush="#475569" Grid.Column="0" Margin="0,0,12,0">
                                    <iconPacks:PackIconMaterialDesign Kind="Refresh" Width="20" Height="20" Foreground="#64748B" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="坐标转换补偿" FontSize="13" FontWeight="Bold" Foreground="#64748B"/>
                                    <TextBlock Text="像素->机械坐标，计算偏差" FontSize="11" Foreground="#64748B"/>
                                </StackPanel>
                                <Rectangle Grid.Column="0" Width="2" Height="16" Fill="#334155" HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="0,0,0,-16"/>
                            </Grid>
                            
                            <!-- Step 5 -->
                            <Grid Margin="0,8,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Border Style="{StaticResource StepCircle}" Background="#1E293B" BorderBrush="#475569" Grid.Column="0" Margin="0,0,12,0">
                                    <iconPacks:PackIconMaterialDesign Kind="Bolt" Width="20" Height="20" Foreground="#64748B" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="三轴联动执行" FontSize="13" FontWeight="Bold" Foreground="#64748B"/>
                                    <TextBlock Text="X/Y/Z 轴插补运动" FontSize="11" Foreground="#64748B"/>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Grid>
                </Border>
                
                <!-- Log -->
                <Border Grid.Row="1" Background="#1E293B" BorderBrush="#334155" BorderThickness="1" CornerRadius="8" Padding="12">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        
                        <Grid Grid.Row="0" Margin="0,0,0,8">
                            <TextBlock Text="运行日志实时输出" FontSize="12" FontWeight="Medium" Foreground="#94A3B8"/>
                            <TextBlock Text="清空" FontSize="11" Foreground="#64748B" HorizontalAlignment="Right" Cursor="Hand"/>
                        </Grid>
                        
                        <Border Grid.Row="1" Background="#0F172A" BorderBrush="#334155" BorderThickness="1" CornerRadius="4" Padding="8">
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <StackPanel>
                                    <TextBlock FontSize="11" FontFamily="Consolas" Margin="0,0,0,4">
                                        <Run Text="[14:02:15.120]" Foreground="#64748B"/><Run Text=" INFO" Foreground="#3B82F6"/><Run Text=" 系统启动自动运行..." Foreground="#CBD5E1"/>
                                    </TextBlock>
                                    <TextBlock FontSize="11" FontFamily="Consolas" Margin="0,0,0,4">
                                        <Run Text="[14:02:15.125]" Foreground="#64748B"/><Run Text=" INFO" Foreground="#3B82F6"/><Run Text=" 加载联动配方 [Task_Assembly_A01] 成功" Foreground="#CBD5E1"/>
                                    </TextBlock>
                                    <TextBlock FontSize="11" FontFamily="Consolas" Margin="0,0,0,4">
                                        <Run Text="[14:02:15.200]" Foreground="#64748B"/><Run Text=" INFO" Foreground="#3B82F6"/><Run Text=" 等待外部触发信号(IN 0.0)" Foreground="#CBD5E1"/>
                                    </TextBlock>
                                    <TextBlock FontSize="11" FontFamily="Consolas" Margin="0,0,0,4">
                                        <Run Text="[14:02:18.550]" Foreground="#64748B"/><Run Text=" WARN" Foreground="#F59E0B"/><Run Text=" 接收到触发信号，启动流程" Foreground="#CBD5E1"/>
                                    </TextBlock>
                                    <TextBlock FontSize="11" FontFamily="Consolas" Margin="0,0,0,4">
                                        <Run Text="[14:02:18.600]" Foreground="#64748B"/><Run Text=" INFO" Foreground="#3B82F6"/><Run Text=" 触发相机采集完成，耗时 50ms" Foreground="#CBD5E1"/>
                                    </TextBlock>
                                    <TextBlock FontSize="11" FontFamily="Consolas" Margin="0,0,0,4">
                                        <Run Text="[14:02:18.680]" Foreground="#64748B"/><Run Text=" SUCC" Foreground="#10B981"/><Run Text=" 视觉匹配成功! Score: 0.982" Foreground="#CBD5E1"/>
                                    </TextBlock>
                                    <TextBlock FontSize="11" FontFamily="Consolas" Margin="0,0,0,4">
                                        <Run Text="[14:02:18.685]" Foreground="#64748B"/><Run Text=" INFO" Foreground="#3B82F6"/><Run Text=" 坐标解算完成: X=125.045, Y=45.002" Foreground="#CBD5E1"/>
                                    </TextBlock>
                                    <TextBlock FontSize="11" FontFamily="Consolas" Margin="0,0,0,4">
                                        <Run Text="[14:02:18.700]" Foreground="#64748B"/><Run Text=" INFO" Foreground="#3B82F6"/><Run Text=" 下发插补运动指令至 ECI1408" Foreground="#CBD5E1"/>
                                    </TextBlock>
                                    <TextBlock FontSize="11" FontFamily="Consolas">
                                        <Run Text="[14:02:19.450]" Foreground="#64748B"/><Run Text=" SUCC" Foreground="#10B981"/><Run Text=" 轴运动到位，流程闭环完成。" Foreground="#CBD5E1"/>
                                    </TextBlock>
                                </StackPanel>
                            </ScrollViewer>
                        </Border>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Page>