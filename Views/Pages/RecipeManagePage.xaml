<Page x:Class="VisionMotionControl.Views.Pages.RecipeManagePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
      Background="#0B0F19">
    
    <Page.Resources>
        <Style x:Key="ActionButton" TargetType="Button">
            <Setter Property="Background" Value="#3B82F6"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#60A5FA"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
        <Style x:Key="SecondaryButton" TargetType="Button">
            <Setter Property="Background" Value="#475569"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#64748B"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
        <Style x:Key="TabButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#94A3B8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="Margin" Value="0,2"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#334155"/>
                                <Setter Property="Foreground" Value="#E2E8F0"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
        <Style x:Key="TabButtonActive" TargetType="Button" BasedOn="{StaticResource TabButton}">
            <Setter Property="Background" Value="#3B82F620"/>
            <Setter Property="Foreground" Value="#60A5FA"/>
            <Setter Property="BorderBrush" Value="#3B82F640"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontWeight" Value="Medium"/>
        </Style>
    </Page.Resources>
    
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        
        <!-- Header -->
        <Border Grid.Row="0" Background="#1E293B" BorderBrush="#334155" BorderThickness="1" CornerRadius="8" Padding="16" Margin="0,0,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <iconPacks:PackIconMaterialDesign Kind="SdStorage" Width="20" Height="20" Foreground="#3B82F6" Margin="0,0,8,0"/>
                    <TextBlock Text="配方参数管理" FontSize="16" FontWeight="SemiBold" Foreground="White"/>
                </StackPanel>
                
                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <Button Style="{StaticResource ActionButton}" Margin="0,0,8,0">
                        <StackPanel Orientation="Horizontal">
                            <iconPacks:PackIconMaterialDesign Kind="Add" Width="14" Height="14" Margin="0,0,6,0"/>
                            <TextBlock Text="新增配方" FontSize="12"/>
                        </StackPanel>
                    </Button>
                    <Rectangle Width="1" Height="20" Fill="#334155" Margin="0,0,8,0"/>
                    <Button Style="{StaticResource SecondaryButton}" Margin="0,0,8,0">
                        <StackPanel Orientation="Horizontal">
                            <iconPacks:PackIconMaterialDesign Kind="Upload" Width="14" Height="14" Margin="0,0,6,0"/>
                            <TextBlock Text="导入" FontSize="12"/>
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource SecondaryButton}">
                        <StackPanel Orientation="Horizontal">
                            <iconPacks:PackIconMaterialDesign Kind="Download" Width="14" Height="14" Margin="0,0,6,0"/>
                            <TextBlock Text="导出" FontSize="12"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>
        
        <!-- Main Content -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            
            <!-- Sidebar Tabs -->
            <Border Grid.Column="0" Background="#1E293B" BorderBrush="#334155" BorderThickness="1" CornerRadius="8" Padding="8" Margin="0,0,8,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    
                    <TextBlock Grid.Row="0" Text="配方分类" FontSize="11" FontWeight="Bold" Foreground="#64748B" Margin="8,8,8,8" />
                    
                    <StackPanel Grid.Row="1">
                        <Button Style="{StaticResource TabButtonActive}" Content="联动配方"/>
                        <Button Style="{StaticResource TabButton}" Content="运动配方"/>
                        <Button Style="{StaticResource TabButton}" Content="视觉配方"/>
                        <Button Style="{StaticResource TabButton}" Content="CAD轨迹配方"/>
                    </StackPanel>
                </Grid>
            </Border>
            
            <!-- Recipe Table -->
            <Border Grid.Column="1" Background="#1E293B" BorderBrush="#334155" BorderThickness="1" CornerRadius="8">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    
                    <!-- Search Bar -->
                    <Border Grid.Row="0" BorderBrush="#334155" BorderThickness="0,0,0,1" Padding="12">
                        <Grid>
                            <Border Background="#0F172A" BorderBrush="#475569" BorderThickness="1" CornerRadius="4" Padding="8,4" Width="280" HorizontalAlignment="Center">
                                <StackPanel Orientation="Horizontal">
                                    <iconPacks:PackIconMaterialDesign Kind="FindInPage" Width="14" Height="14" Foreground="#64748B" Margin="0,0,8,0"/>
                                    <TextBox Background="Transparent" BorderThickness="0" Foreground="#E2E8F0" FontSize="12" Text="搜索配方名称 / 编号..." Width="220"/>
                                </StackPanel>
                            </Border>
                            <TextBlock Text="共找到 4 个配方" FontSize="11" Foreground="#64748B" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                        </Grid>
                    </Border>
                    
                    <!-- Table -->
                    <Grid Grid.Row="1" Margin="12">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        
                        <!-- Header -->
                        <Grid Grid.Row="0" Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="140"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="配方编号" FontSize="12" Foreground="#94A3B8" FontWeight="Medium"/>
                            <TextBlock Grid.Column="1" Text="配方名称" FontSize="12" Foreground="#94A3B8" FontWeight="Medium"/>
                            <TextBlock Grid.Column="2" Text="描述" FontSize="12" Foreground="#94A3B8" FontWeight="Medium"/>
                            <TextBlock Grid.Column="3" Text="更新时间" FontSize="12" Foreground="#94A3B8" FontWeight="Medium"/>
                            <TextBlock Grid.Column="4" Text="状态" FontSize="12" Foreground="#94A3B8" FontWeight="Medium"/>
                            <TextBlock Grid.Column="5" Text="操作" FontSize="12" Foreground="#94A3B8" FontWeight="Medium" HorizontalAlignment="Right"/>
                        </Grid>
                        
                        <StackPanel Grid.Row="1">
                            <!-- Row 1 -->
                            <Border Background="#0F172A" BorderBrush="#334155" BorderThickness="0,0,0,1" Padding="0,12">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="140"/>
                                        <ColumnDefinition Width="80"/>
                                        <ColumnDefinition Width="140"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="REC-L-001" FontSize="12" Foreground="#CBD5E1" FontFamily="Consolas"/>
                                    <TextBlock Grid.Column="1" Text="Task_Assembly_A01" FontSize="12" Foreground="#E2E8F0" FontWeight="Bold"/>
                                    <TextBlock Grid.Column="2" Text="A款工件组装基础联动" FontSize="12" Foreground="#64748B"/>
                                    <TextBlock Grid.Column="3" Text="2026-06-08 10:20" FontSize="12" Foreground="#94A3B8"/>
                                    <Border Grid.Column="4" Background="#10B98120" BorderBrush="#10B98140" BorderThickness="1" CornerRadius="4" Padding="4,2" HorizontalAlignment="Left">
                                        <StackPanel Orientation="Horizontal">
                                            <Ellipse Width="4" Height="4" Fill="#10B981" Margin="0,0,4,0"/>
                                            <TextBlock Text="当前启用" FontSize="10" Foreground="#10B981"/>
                                        </StackPanel>
                                    </Border>
                                    <StackPanel Grid.Column="5" Orientation="Horizontal" HorizontalAlignment="Right">
                                        <Button Background="Transparent" BorderThickness="0" Padding="4" Cursor="Hand">
                                            <iconPacks:PackIconMaterialDesign Kind="CreditCard" Width="14" Height="14" Foreground="#94A3B8"/>
                                        </Button>
                                        <Button Background="Transparent" BorderThickness="0" Padding="4" Cursor="Hand">
                                            <iconPacks:PackIconMaterialDesign Kind="Delete" Width="14" Height="14" Foreground="#94A3B8"/>
                                        </Button>
                                    </StackPanel>
                                </Grid>
                            </Border>
                            
                            <!-- Row 2 -->
                            <Border Background="Transparent" BorderBrush="#334155" BorderThickness="0,0,0,1" Padding="0,12">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="140"/>
                                        <ColumnDefinition Width="80"/>
                                        <ColumnDefinition Width="140"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="REC-L-002" FontSize="12" Foreground="#CBD5E1" FontFamily="Consolas"/>
                                    <TextBlock Grid.Column="1" Text="Task_Assembly_B02" FontSize="12" Foreground="#E2E8F0" FontWeight="Bold"/>
                                    <TextBlock Grid.Column="2" Text="B款工件高精度打孔" FontSize="12" Foreground="#64748B"/>
                                    <TextBlock Grid.Column="3" Text="2026-06-07 15:45" FontSize="12" Foreground="#94A3B8"/>
                                    <Border Grid.Column="4" Background="#334155" BorderBrush="#475569" BorderThickness="1" CornerRadius="4" Padding="4,2" HorizontalAlignment="Left">
                                        <StackPanel Orientation="Horizontal">
                                            <Ellipse Width="4" Height="4" Fill="#64748B" Margin="0,0,4,0"/>
                                            <TextBlock Text="未启用" FontSize="10" Foreground="#64748B"/>
                                        </StackPanel>
                                    </Border>
                                    <StackPanel Grid.Column="5" Orientation="Horizontal" HorizontalAlignment="Right">
                                        <Button Background="Transparent" BorderThickness="0" Padding="4" Cursor="Hand">
                                            <iconPacks:PackIconMaterialDesign Kind="Bolt" Width="14" Height="14" Foreground="#3B82F6"/>
                                        </Button>
                                        <Button Background="Transparent" BorderThickness="0" Padding="4" Cursor="Hand">
                                            <iconPacks:PackIconMaterialDesign Kind="CreditCard" Width="14" Height="14" Foreground="#94A3B8"/>
                                        </Button>
                                        <Button Background="Transparent" BorderThickness="0" Padding="4" Cursor="Hand">
                                            <iconPacks:PackIconMaterialDesign Kind="Delete" Width="14" Height="14" Foreground="#94A3B8"/>
                                        </Button>
                                    </StackPanel>
                                </Grid>
                            </Border>
                            
                            <!-- Row 3 -->
                            <Border Background="Transparent" BorderBrush="#334155" BorderThickness="0,0,0,1" Padding="0,12">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="140"/>
                                        <ColumnDefinition Width="80"/>
                                        <ColumnDefinition Width="140"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="REC-L-003" FontSize="12" Foreground="#CBD5E1" FontFamily="Consolas"/>
                                    <TextBlock Grid.Column="1" Text="Detect_Yield_Test" FontSize="12" Foreground="#E2E8F0" FontWeight="Bold"/>
                                    <TextBlock Grid.Column="2" Text="测试良率全检流程" FontSize="12" Foreground="#64748B"/>
                                    <TextBlock Grid.Column="3" Text="2026-06-05 09:12" FontSize="12" Foreground="#94A3B8"/>
                                    <Border Grid.Column="4" Background="#334155" BorderBrush="#475569" BorderThickness="1" CornerRadius="4" Padding="4,2" HorizontalAlignment="Left">
                                        <StackPanel Orientation="Horizontal">
                                            <Ellipse Width="4" Height="4" Fill="#64748B" Margin="0,0,4,0"/>
                                            <TextBlock Text="未启用" FontSize="10" Foreground="#64748B"/>
                                        </StackPanel>
                                    </Border>
                                    <StackPanel Grid.Column="5" Orientation="Horizontal" HorizontalAlignment="Right">
                                        <Button Background="Transparent" BorderThickness="0" Padding="4" Cursor="Hand">
                                            <iconPacks:PackIconMaterialDesign Kind="Bolt" Width="14" Height="14" Foreground="#3B82F6"/>
                                        </Button>
                                        <Button Background="Transparent" BorderThickness="0" Padding="4" Cursor="Hand">
                                            <iconPacks:PackIconMaterialDesign Kind="CreditCard" Width="14" Height="14" Foreground="#94A3B8"/>
                                        </Button>
                                        <Button Background="Transparent" BorderThickness="0" Padding="4" Cursor="Hand">
                                            <iconPacks:PackIconMaterialDesign Kind="Delete" Width="14" Height="14" Foreground="#94A3B8"/>
                                        </Button>
                                    </StackPanel>
                                </Grid>
                            </Border>
                            
                            <!-- Row 4 -->
                            <Border Background="Transparent" BorderBrush="#334155" BorderThickness="0,0,0,1" Padding="0,12">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="140"/>
                                        <ColumnDefinition Width="80"/>
                                        <ColumnDefinition Width="140"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="REC-L-004" FontSize="12" Foreground="#CBD5E1" FontFamily="Consolas"/>
                                    <TextBlock Grid.Column="1" Text="Camera_Calib_Seq" FontSize="12" Foreground="#E2E8F0" FontWeight="Bold"/>
                                    <TextBlock Grid.Column="2" Text="九点标定自动取图流程" FontSize="12" Foreground="#64748B"/>
                                    <TextBlock Grid.Column="3" Text="2026-06-01 11:30" FontSize="12" Foreground="#94A3B8"/>
                                    <Border Grid.Column="4" Background="#334155" BorderBrush="#475569" BorderThickness="1" CornerRadius="4" Padding="4,2" HorizontalAlignment="Left">
                                        <StackPanel Orientation="Horizontal">
                                            <Ellipse Width="4" Height="4" Fill="#64748B" Margin="0,0,4,0"/>
                                            <TextBlock Text="未启用" FontSize="10" Foreground="#64748B"/>
                                        </StackPanel>
                                    </Border>
                                    <StackPanel Grid.Column="5" Orientation="Horizontal" HorizontalAlignment="Right">
                                        <Button Background="Transparent" BorderThickness="0" Padding="4" Cursor="Hand">
                                            <iconPacks:PackIconMaterialDesign Kind="Bolt" Width="14" Height="14" Foreground="#3B82F6"/>
                                        </Button>
                                        <Button Background="Transparent" BorderThickness="0" Padding="4" Cursor="Hand">
                                            <iconPacks:PackIconMaterialDesign Kind="CreditCard" Width="14" Height="14" Foreground="#94A3B8"/>
                                        </Button>
                                        <Button Background="Transparent" BorderThickness="0" Padding="4" Cursor="Hand">
                                            <iconPacks:PackIconMaterialDesign Kind="Delete" Width="14" Height="14" Foreground="#94A3B8"/>
                                        </Button>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </StackPanel>
                    </Grid>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Page>